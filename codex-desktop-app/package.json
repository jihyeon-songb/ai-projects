{
  "name": "orangi-codex-companion",
  "version": "0.1.0",
  "description": "오랑이 — 화면 위에 떠다니는 Codex 컴패니언 데스크탑 캐릭터",
  "main": "./out/main/index.js",
  "author": "",
  "license": "MIT",
  "scripts": {
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "start": "electron-vite preview",
    "pack": "npm run build && electron-builder --dir",
    "dist": "npm run build && electron-builder",
    "reinstall": "bash scripts/reinstall.sh",
    "typecheck": "tsc --noEmit -p tsconfig.node.json && tsc --noEmit -p tsconfig.web.json"
  },
  "dependencies": {
    "electron-updater": "^6.3.9"
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "@types/react": "^19.0.2",
    "@types/react-dom": "^19.0.2",
    "@vitejs/plugin-react": "^4.3.4",
    "electron": "^33.2.1",
    "electron-builder": "^25.1.8",
    "electron-vite": "^3.0.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "typescript": "^5.7.2",
    "vite": "^6.0.3"
  },
  "build": {
    "appId": "com.orangi.codex.companion",
    "productName": "Orangi",
    "files": ["out/**/*", "assets/**/*"],
    "extraResources": [{ "from": "hooks", "to": "hooks" }],
    "mac": { "category": "public.app-category.developer-tools" }
  }
}