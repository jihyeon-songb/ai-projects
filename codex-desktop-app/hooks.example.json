{
  "//": "이 파일을 ~/.codex/hooks.json 또는 <repo>/.codex/hooks.json 으로 복사하고 <앱경로>를 실제 경로로 바꾸세요.",
  "hooks": {
    "PreToolUse": [
      {
        "matcher": ".*",
        "hooks": [
          {
            "type": "command",
            "command": "node \"<앱경로>/hooks/pre_tool_use.js\"",
            "timeout": 660,
            "statusMessage": "오랑이에게 허용 여부 묻는 중…"
          }
        ]
      }
    ]
  }
}
